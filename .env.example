# LLM Configuration (litellm format)
# Examples: deepseek/deepseek-chat, openai/gpt-4o, anthropic/claude-3-5-sonnet-20241022, glm-4
LITELLM_MODEL=deepseek/deepseek-chat
LITELLM_API_KEY=sk-your-key-here
LITELLM_API_BASE=
LITELLM_TIMEOUT=60

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=yuqing

# ChromaDB
CHROMA_PATH=data/chroma_db

# Application defaults
LANGUAGE=zh
MAX_CONTEXT_MESSAGES=20
MEMORY_RECALL_COUNT=5

# Debug
LOG_LEVEL=INFO
