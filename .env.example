# LLM API 配置（OpenAI 兼容格式）
# 示例: openai/mimo-v2.5-pro, openai/deepseek-chat, openai/gpt-4o
LITELLM_MODEL=openai/deepseek-chat
LITELLM_API_KEY=sk-your-key-here
LITELLM_API_BASE=https://api.deepseek.com/v1
LITELLM_TIMEOUT=60

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=yuqing

# Application defaults
LANGUAGE=zh
MAX_CONTEXT_MESSAGES=20
MEMORY_RECALL_COUNT=5

# Debug
LOG_LEVEL=INFO
